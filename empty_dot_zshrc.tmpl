
# ------------------------------------------------------------------------------
# Path - The higher it is, the more priority it has
# ------------------------------------------------------------------------------
typeset -U path  # Elimina duplicados automáticamente
path=(
	"$HOME/bin"
	"$HOME/.local/bin"
	"$HOME/.opencode/bin"
	${JAVA_HOME:+"$JAVA_HOME/bin"}
	${GEM_HOME:+"$GEM_HOME/bin"}
	${GOPATH:+"$GOPATH/bin"}
	"$HOME/.cargo/bin"
	"/usr/local/opt/ruby/bin"
	"/usr/local/opt/python/libexec/bin"
	"/opt/homebrew/bin"
	"/usr/local/bin"
	"/usr/local/sbin"
	"/bin"
	"/usr/bin"
	"/usr/sbin"
	"/sbin"
	"/snap/bin"
	$path
)

# --- Configuración Básica ---
export EDITOR="nvim"

# --- Historial ---
HISTFILE=$HOME/.zsh_history
HISTSIZE=10000
SAVEHIST=10000

setopt append_history
setopt share_history
setopt hist_expire_dups_first
setopt hist_ignore_dups
setopt hist_ignore_space
setopt hist_verify
setopt extended_history

# --- Alias Inteligentes ---

# EZA command
if command -v eza &> /dev/null; then
	alias ls="eza --icons --git"
	alias l="eza -l --icons --git -a"
	alias lt="eza --tree --level=2 --long --icons --git"
	alias ltree="eza --tree --level=2  --icons --git"
fi

# BAT
if command -v bat &> /dev/null; then
    alias cat='bat'
elif command -v batcat &> /dev/null; then
    alias cat='batcat'
fi

# NVIM
alias v="nvim"
alias vi="nvim"
alias vim="nvim"

# ZOXIDE
if command -v z &> /dev/null; then
	alias cd='z'
fi

# GIT
alias gadd="git add"
alias gc='git commit -m'
alias gca="git add --all && git commit --amend --no-edit"
alias gco="git checkout"
alias gdiff='git diff'
alias gst="git status "
alias gps="git push"
alias gpl="git pull"
alias gb="git branch"
alias gl='git log'

if [ -f ~/.zsh/zsh-autosuggestions/zsh-autosuggestions.zsh ]; then
    source ~/.zsh/zsh-autosuggestions/zsh-autosuggestions.zsh
fi

# --- Configurar fzf ---
if [ -f /usr/share/doc/fzf/examples/key-bindings.zsh ]; then
    source /usr/share/doc/fzf/examples/key-bindings.zsh
    source /usr/share/doc/fzf/examples/completion.zsh
fi

# NVM - Usar siempre ~/.nvm como directorio canónico
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"
[ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"

# STEL
alias tunnel="cloudflared tunnel --url http://localhost:8080"
alias projects='cd ~/workspaces && cd "$(find . -mindepth 2 -maxdepth 2 -type d | sed "s|^\./||" | fzf --height 15% --reverse)"'
alias autoskill='npx autoskills'

# --- Inicializaciones (al final para evitar warnings de zoxide) ---

# Starship (Prompt)
eval "$(starship init zsh)"

# Zoxide (debe ir al final del archivo)
eval "$(zoxide init zsh)"
